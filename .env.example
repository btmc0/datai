# ══════════════════════════════════════════════════
# DATAI Environment Configuration
# Copy this file to .env and fill in the values
# ══════════════════════════════════════════════════

# ── Shared (used by both Open WebUI and DATAI) ──

# JWT signing secret — MUST match between Open WebUI and datai-server
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-to-random-string

# ── DATAI Server ──

# Encryption key for SSH private keys at rest (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-to-another-random-string

# SQLite database path (inside the datai-data volume)
DATAI_DB_PATH=/data/datai.db

# ── Tailscale ──

# Tailscale auth key for joining the tailnet
# Get from: https://login.tailscale.com/admin/settings/keys
# Use a reusable, ephemeral key for containers
TS_AUTHKEY=tskey-auth-xxxxx

# ── Open WebUI ──

# Allow new user registration (disable in production)
ENABLE_SIGNUP=false

# ── Nginx / Domain ──

# Your domain (update nginx.conf ssl_certificate paths to match)
DOMAIN=datai.yourdomain.com
